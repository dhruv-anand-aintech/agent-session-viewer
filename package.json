{
  "name": "agent-session-viewer",
  "version": "0.1.1",
  "description": "Live multi-platform AI coding session viewer — Claude Code, Cursor, Codex, OpenCode, Hermes, Antigravity",
  "type": "module",
  "bin": {
    "agent-session-viewer": "bin/agent-session-viewer.mjs"
  },
  "files": [
    "bin/",
    "dist/",
    "lib/",
    "local-server.mjs",
    "build-cache.mjs",
    "setup-local.mjs",
    "shared-utils.mjs",
    "platform-readers.mjs"
  ],
  "keywords": [
    "ai",
    "claude",
    "cursor",
    "codex",
    "opencode",
    "session-viewer",
    "devtools"
  ],
  "author": "Dhruv Anand",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dhruv-anand-aintech/agent-session-viewer.git"
  },
  "scripts": {
    "prepare": "npm run build",
    "dev": "vite",
    "dev:api": "node dev-server.mjs",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "local": "node scripts/run-local-dev.mjs",
    "build-cache": "node build-cache.mjs",
    "setup": "node setup-local.mjs",
    "setup:cloudflare": "node setup.mjs",
    "deploy": "node deploy.mjs",
    "daemon": "node daemon/watch.mjs",
    "daemon:launchd-install": "bash scripts/install-launchd-daemon.sh",
    "daemon:launchd-uninstall": "bash scripts/uninstall-launchd-daemon.sh",
    "daemon:launchd-restart": "bash -c 'launchctl kickstart -k gui/$(id -u)/com.dhruvanand.agent-session-viewer.daemon'"
  },
  "dependencies": {
    "fuse.js": "^7.3.0",
    "marked": "^17.0.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@cloudflare/kv-asset-handler": "^0.4.2",
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "wrangler": "^4.76.0"
  }
}
