{
  "name": "claude-session-viewer",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "node dev-server.mjs",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "local": "concurrently -n api,ui --kill-others \"node --watch local-server.mjs\" \"vite\"",
    "deploy": "node deploy.mjs",
    "daemon": "node daemon/watch.mjs",
    "daemon:launchd-install": "bash scripts/install-launchd-daemon.sh",
    "daemon:launchd-uninstall": "bash scripts/uninstall-launchd-daemon.sh",
    "daemon:launchd-restart": "bash -c 'launchctl kickstart -k gui/$(id -u)/com.dhruvanand.claude-session-viewer.daemon'"
  },
  "dependencies": {
    "marked": "^17.0.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@cloudflare/kv-asset-handler": "^0.4.2",
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "wrangler": "^4.76.0"
  }
}
